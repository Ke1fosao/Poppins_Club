# --- Frontend (Vite) environment ---
# Скопіюйте у .env (.env у gitignore — секрети не йдуть у репо).

# Base URL для API. У dev — http://127.0.0.1:8000.
# У production (коли фронт і бек хостяться на одному домені) — залиште порожнім.
VITE_API_BASE=http://127.0.0.1:8000

# ⚠️  VITE_GEMINI_API_KEY БІЛЬШЕ НЕ ПОТРІБЕН!
# Gemini-ключ зараз живе тільки на бекенді (в env-змінній GEMINI_API_KEY).
# Фронт спілкується з AI через Django-проксі /api/chat/.
