# --- Frontend (Vite) environment ---
# Скопіюйте у .env та .env.production і заповніть.

# Base URL для API. У dev — http://127.0.0.1:8000.
# У production (коли фронт і бек хостяться на одному домені) — залиште порожнім.
VITE_API_BASE=http://127.0.0.1:8000

# Google Gemini API key для ШІ-помічника
# Отримати: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
