# --- Backend (Django) environment ---
# На локальному ПК це необов'язково — настройки за замовчуванням працюють у DEBUG=True.
# Для PythonAnywhere / прод-хостинга — встановіть ці змінні у WSGI-файлі або
# у налаштуваннях середовища PA Bash console (export VAR=...).

# Згенеруйте новий ключ для прода: https://djecrety.ir/
DJANGO_SECRET_KEY=replace-me-with-a-real-secret

# True для розробки, False для прода
DJANGO_DEBUG=False

# Через кому: домени, що дозволені обслуговувати сайт
DJANGO_ALLOWED_HOSTS=yourusername.pythonanywhere.com

# (опц.) Для CSRF з кастомного домена
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# (опц.) Якщо фронт і бек на різних доменах
CORS_ALLOWED_ORIGINS=

# Gemini AI ключ для /api/chat/ ендпоінта
# Отримати: https://aistudio.google.com/apikey
# Цей ключ ніколи не йде у фронтенд і не комітиться у репо.
GEMINI_API_KEY=
